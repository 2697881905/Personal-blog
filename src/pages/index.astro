---
import Heatmap from '../components/react/Heatmap';
import Terminal from '../components/react/Terminal';
import Hero from '../components/vue/Hero.vue';
import ProfileSidebar from '../components/vue/ProfileSidebar.vue';
import SkillCard from '../components/vue/SkillCard.vue';
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../data/profile.json';
import projects from '../data/projects.json';
import skills from '../data/skills.json';

type Skill = {
  name: string;
  logo: string;
};
---

<BaseLayout profile={profile}>
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-5 px-4 pt-12 pb-5 sm:px-6 sm:pt-20 lg:block lg:pr-[292px]">
    <div class="space-y-4 lg:fixed lg:right-[max(1.5rem,calc((100vw-72rem)/2+1.5rem))] lg:top-[49px] lg:z-20" data-entrance>
      <ProfileSidebar client:load profile={profile} />
      <div class="hidden w-[220px] mx-auto lg:block">
        <Terminal client:only="react" />
      </div>
    </div>

    <div class="min-w-0 space-y-5">
      <section class="matcha-signature-wrap" aria-label="This is Matcha" data-entrance>
        <svg class="matcha-signature" viewBox="0 0 1060 220" role="img" aria-hidden="true">
          <defs>
            <linearGradient id="matcha-signature-ink" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#ff6b6b" />
              <stop offset="16%" stop-color="#ffa502" />
              <stop offset="33%" stop-color="#ffd93d" />
              <stop offset="50%" stop-color="#6bcb77" />
              <stop offset="66%" stop-color="#4d96ff" />
              <stop offset="83%" stop-color="#a855f7" />
              <stop offset="100%" stop-color="#ec4899" />
            </linearGradient>
            <linearGradient id="matcha-signature-ink-glass" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#ff8a8a" stop-opacity="0.2" />
              <stop offset="16%" stop-color="#ffbe4d" stop-opacity="0.2" />
              <stop offset="33%" stop-color="#ffe27a" stop-opacity="0.2" />
              <stop offset="50%" stop-color="#8fd99e" stop-opacity="0.2" />
              <stop offset="66%" stop-color="#7fb0ff" stop-opacity="0.2" />
              <stop offset="83%" stop-color="#c084fc" stop-opacity="0.2" />
              <stop offset="100%" stop-color="#f472b6" stop-opacity="0.2" />
            </linearGradient>
            <linearGradient id="matcha-signature-glass-hi" x1="0%" y1="0%" x2="75%" y2="100%">
              <stop offset="0%" stop-color="#ffffff" stop-opacity="0" />
              <stop offset="34%" stop-color="#ffffff" stop-opacity="0" />
              <stop offset="48%" stop-color="#ffffff" stop-opacity="0.62" />
              <stop offset="60%" stop-color="#ffffff" stop-opacity="0" />
              <stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
            </linearGradient>
          </defs>
          <text class="matcha-signature-ghost" x="24" y="132">This is Matcha</text>
          <text class="matcha-signature-stroke" x="24" y="132">This is Matcha</text>
          <text class="matcha-signature-fill" x="24" y="132">This is Matcha</text>
          <text class="matcha-signature-glass-highlight" x="24" y="132">This is Matcha</text>
          <path
            class="matcha-signature-flourish"
            d="M74 164 C 216 198, 322 137, 448 162 S 676 204, 984 142"
          />
        </svg>
        <p class="matcha-tagline lg:ml-0 lg:text-right"><span class="emoji-lg">🎹</span>从<span class="tagline-key">键盘</span>敲到<span class="tagline-key">琴键</span>，从<span class="tagline-key">琴键</span>弹到<span class="tagline-key">键盘</span></p>

        <nav aria-label="社交链接" class="social-nav mt-6 flex items-center justify-start gap-3 lg:justify-end">
          <a href="https://github.com/2697881905" target="_blank" rel="noreferrer" data-label="GitHub" class="group flex h-12 items-center justify-center overflow-hidden rounded-xl border border-border/60 bg-surface hover:border-accent/50 hover:bg-surface-strong">
            <svg class="h-6 w-6 text-text transition group-hover:text-accent" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.6.113.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.105 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="mailto:2697889105@qq.com" title="邮箱" data-label="邮箱" class="group flex h-12 items-center justify-center overflow-hidden rounded-xl border border-border/60 bg-surface hover:border-accent/50 hover:bg-surface-strong">
            <svg class="h-6 w-6 text-text transition group-hover:text-accent" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          </a>
          <a href="#" title="赞赏支持" data-label="赞赏支持" data-qr="/qrcodes/tip.png" class="group social-qr-trigger flex h-12 items-center justify-center overflow-hidden rounded-xl border border-border/60 bg-surface hover:border-accent/50 hover:bg-surface-strong">
            <svg class="h-6 w-6 text-text transition group-hover:text-accent" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.216 6.415l-.132-.666c-.119-.598-.388-1.163-1.001-1.379-.197-.069-.42-.098-.57-.241-.152-.143-.196-.366-.231-.572-.065-.378-.125-.756-.192-1.133-.057-.325-.102-.69-.25-.987-.195-.4-.597-.634-.996-.788a5.723 5.723 0 00-.626-.194c-1-.263-2.05-.36-3.077-.416a25.834 25.834 0 00-3.7.062c-.915.083-1.88.184-2.75.5-.318.116-.646.256-.888.501-.297.302-.393.77-.177 1.146.154.267.415.456.692.58.36.162.737.284 1.123.366 1.075.238 2.189.331 3.287.37 1.218.05 2.437.01 3.65-.118.299-.033.598-.073.896-.119.352-.054.578-.513.474-.834-.124-.383-.457-.531-.834-.473-.466.074-.96.108-1.382.146-1.177.08-2.358.082-3.536.006a22.228 22.228 0 01-1.157-.107c-.086-.01-.18-.025-.258-.036-.243-.036-.484-.08-.724-.13-.111-.027-.111-.185 0-.212h.005c.277-.06.557-.108.838-.147h.002c.131-.009.263-.032.394-.048a25.076 25.076 0 013.426-.12c.674.019 1.347.067 2.017.144l.228.031c.267.04.533.088.798.145.392.085.895.113 1.07.542.055.137.08.288.111.431l.319 1.484a.237.237 0 01-.199.284h-.003c-.037.006-.075.01-.112.015a36.704 36.704 0 01-4.743.295 37.059 37.059 0 01-4.699-.304c-.14-.017-.293-.042-.417-.06-.326-.048-.649-.108-.973-.161-.393-.065-.768-.032-1.123.161-.29.16-.527.404-.675.701-.154.316-.199.66-.267 1-.069.34-.176.707-.135 1.056.087.753.613 1.365 1.37 1.502a39.69 39.69 0 0011.343.376.483.483 0 01.535.53l-.071.697-1.018 9.907c-.041.41-.047.832-.125 1.237-.122.637-.553 1.028-1.182 1.171-.577.131-1.165.2-1.756.205-.656.004-1.31-.025-1.966-.022-.699.004-1.556-.06-2.095-.58-.475-.458-.54-1.174-.605-1.793l-.731-7.013-.322-3.094c-.037-.351-.286-.695-.678-.678-.336.015-.718.3-.678.679l.228 2.185.949 9.112c.147 1.344 1.174 2.068 2.446 2.272.742.12 1.503.144 2.257.156.966.016 1.942.053 2.892-.122 1.408-.258 2.465-1.198 2.616-2.657.34-3.332.683-6.663 1.024-9.995l.215-2.087a.484.484 0 01.39-.426c.402-.078.787-.212 1.074-.518.455-.488.546-1.124.385-1.766zm-1.478.772c-.145.137-.363.201-.578.233-2.416.359-4.866.54-7.308.46-1.748-.06-3.477-.254-5.207-.498-.17-.024-.353-.055-.47-.18-.22-.236-.111-.71-.054-.995.052-.26.152-.609.463-.646.484-.057 1.046.148 1.526.22.577.088 1.156.159 1.737.212 2.48.226 5.002.19 7.472-.14.45-.06.899-.13 1.345-.21.399-.072.84-.206 1.08.206.166.281.188.657.162.974a.544.544 0 01-.169.364zm-6.159 3.9c-.862.37-1.84.788-3.109.788a5.884 5.884 0 01-1.569-.217l.877 9.004c.065.78.717 1.38 1.5 1.38 0 0 1.243.065 1.658.065.447 0 1.786-.065 1.786-.065.783 0 1.434-.6 1.499-1.38l.94-9.95a3.996 3.996 0 00-1.322-.238c-.826 0-1.491.284-2.26.613z"/></svg>
          </a>
          <a href="#" title="QQ" data-label="QQ" data-qr="/qrcodes/qq.png" class="group social-qr-trigger flex h-12 items-center justify-center overflow-hidden rounded-xl border border-border/60 bg-surface hover:border-accent/50 hover:bg-surface-strong">
            <svg class="h-6 w-6 text-text transition group-hover:text-accent" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21.395 15.035a40 40 0 0 0-.803-2.264l-1.079-2.695c.001-.032.014-.562.014-.836C19.526 4.632 17.351 0 12 0S4.474 4.632 4.474 9.241c0 .274.013.804.014.836l-1.08 2.695a39 39 0 0 0-.802 2.264c-1.021 3.283-.69 4.643-.438 4.673.54.065 2.103-2.472 2.103-2.472 0 1.469.756 3.387 2.394 4.771-.612.188-1.363.479-1.845.835-.434.32-.379.646-.301.778.343.578 5.883.369 7.482.189 1.6.18 7.14.389 7.483-.189.078-.132.132-.458-.301-.778-.483-.356-1.233-.646-1.846-.836 1.637-1.384 2.393-3.302 2.393-4.771 0 0 1.563 2.537 2.103 2.472.251-.03.581-1.39-.438-4.673"/></svg>
          </a>
          <a href="#" title="微信" data-label="微信" data-qr="/qrcodes/wechat.jpg" class="group social-qr-trigger flex h-12 items-center justify-center overflow-hidden rounded-xl border border-border/60 bg-surface hover:border-accent/50 hover:bg-surface-strong">
            <svg class="h-6 w-6 text-text transition group-hover:text-accent" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178A1.17 1.17 0 0 1 4.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178 1.17 1.17 0 0 1-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 0 1 .598.082l1.584.926a.272.272 0 0 0 .14.047c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 0 1-.023-.156.49.49 0 0 1 .201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-6.656-6.088V8.89c-.135-.01-.27-.027-.407-.03zm-2.53 3.274c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.97-.982zm4.844 0c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.969-.982z"/></svg>
          </a>
        </nav>

        <!-- QR Code Modal (hidden by default) -->
        <div id="qr-modal" class="qr-modal" role="dialog" aria-label="二维码" aria-hidden="true">
          <div class="qr-modal__backdrop"></div>
          <div class="qr-modal__card">
            <button class="qr-modal__close" type="button" aria-label="关闭">&times;</button>
            <img id="qr-modal-img" src="" alt="" class="qr-modal__img" />
            <p id="qr-modal-label" class="qr-modal__label"></p>
          </div>
        </div>

        <script is:inline>
          (function () {
            var modal = document.getElementById('qr-modal');
            if (!modal) return;
            var img = document.getElementById('qr-modal-img');
            var label = document.getElementById('qr-modal-label');
            var backdrop = modal.querySelector('.qr-modal__backdrop');
            var closeBtn = modal.querySelector('.qr-modal__close');

            function openQr(src, title) {
              // 将弹窗移到 <body> 下，避免祖先元素的 transform 导致 position:fixed 失效
              if (modal.parentElement !== document.body) {
                document.body.appendChild(modal);
              }
              if (img) { img.src = src; img.alt = title + ' 二维码'; }
              if (label) { label.textContent = '扫一扫 · ' + title; }
              modal.classList.add('is-open');
              modal.setAttribute('aria-hidden', 'false');
              document.body.style.overflow = 'hidden';
            }
            function closeQr() {
              modal.classList.remove('is-open');
              modal.setAttribute('aria-hidden', 'true');
              document.body.style.overflow = '';
              if (img) { img.src = ''; }
            }

            document.querySelectorAll('.social-qr-trigger').forEach(function (el) {
              el.addEventListener('click', function (e) {
                e.preventDefault();
                var qrSrc = el.getAttribute('data-qr');
                var qrLabel = el.getAttribute('data-label') || '';
                if (qrSrc) openQr(qrSrc, qrLabel);
              });
            });

            if (backdrop) backdrop.addEventListener('click', closeQr);
            if (closeBtn) closeBtn.addEventListener('click', closeQr);
            document.addEventListener('keydown', function (e) {
              if (e.key === 'Escape' && modal.classList.contains('is-open')) closeQr();
            });
          })();
        </script>
      </section>

      <section data-reveal style="content-visibility:auto; contain-intrinsic-size:320px;">
        <Heatmap client:only="react" />
      </section>

      <section data-reveal>
        <Hero client:load />
      </section>

      <section id="projects" class="pb-10" data-reveal>
        <div class="mb-5">
          <h2 class="mt-3 text-2xl font-extrabold tracking-tight text-text text-balance sm:text-3xl section-title"><span class="emoji-lg">🗑️</span> 我的垃圾项目</h2>
        </div>

        <div class="grid gap-5 xl:grid-cols-2">
          {
            projects.filter((project) => project.title.includes('MindType')).map((project) => (
              <article class="liquid-surface liquid-hover relative rounded-2xl p-3 sm:p-5 flex flex-col gap-4">
                <a href="https://mindtype.cn" class="mindtype-card-link" aria-label="访问 MindType 项目官网" target="_blank" rel="noreferrer"></a>
                <div class="flex items-start justify-between gap-4">
                  <h3 class="min-w-0 flex-1 text-2xl font-semibold text-text sm:text-3xl">{project.title}</h3>
                  {project.logo && (
                    <img
                      src={project.logo}
                      alt={`${project.title} logo`}
                      class="mindtype-logo h-28 w-28 shrink-0 rounded-2xl sm:h-40 sm:w-40"
                      width="160"
                      height="160"
                    />
                  )}
                </div>
                <p class="text-sm leading-7 text-muted">{project.description}</p>
                <div class="flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="liquid-chip rounded-xl px-2 py-1 text-xs text-text">{tag}</span>
                  ))}
                </div>
                <a
                  href={project.gitee}
                  class="mindtype-gitee mt-1 inline-flex items-center text-sm font-semibold text-accent transition hover:text-text hover:underline hover:underline-offset-4"
                  target="_blank"
                  rel="noreferrer"
                >
                  Gitee
                </a>
              </article>
            ))
          }
        </div>
      </section>

      <section data-reveal>
        <div class="mb-5">
          <h2 class="mt-3 text-2xl font-extrabold tracking-tight text-text text-balance sm:text-3xl section-title"><span class="emoji-lg">⚡️</span> 技术栈</h2>
        </div>

        <div class="grid grid-cols-8 gap-2 lg:grid-cols-10">
          {
            (skills as Skill[]).map((skill) => (
              <SkillCard name={skill.name} logo={skill.logo} />
            ))
          }
        </div>
      </section>
      </div>
  </div>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReduced) {
      gsap.registerPlugin(ScrollTrigger);
      ScrollTrigger.config({ ignoreMobileResize: true });

      // 进入网页过渡动画：遮罩揭开 + 首屏内容错峰淡入
      const entrance = document.querySelector('#page-entrance');
      if (entrance) {
        const bits = gsap.utils.toArray('[data-entrance]');
        const tl = gsap.timeline({
          onComplete: () => { entrance.classList.add('is-done'); }
        });
        // 遮罩停留片刻后淡出（用 autoAlpha 同时控制 opacity + visibility）
        tl.to(entrance, { autoAlpha: 0, duration: 0.7, ease: 'power2.inOut', delay: 0.5 });
        // 内容在遮罩揭开的同时错峰淡入上浮（position 参数 "-=0.25" 与淡出重叠）
        if (bits.length) {
          tl.from(bits, { autoAlpha: 0, y: 24, duration: 0.7, ease: 'power3.out', stagger: 0.14 }, '-=0.25');
        }
        tl.set(entrance, { display: 'none' });
      }

      const targets = gsap.utils.toArray<HTMLElement>('[data-reveal]');
      targets.forEach((el) => {
        gsap.from(el, {
          opacity: 0,
          y: 28,
          duration: 0.7,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 88%',
            toggleActions: 'play none none none'
          }
        });
      });
    }

  </script>
</BaseLayout>
